# Supabase Bilgileri (Örnek)
VITE_SUPABASE_URL=https://ornek-proje-id.supabase.co
VITE_SUPABASE_ANON_KEY=senin_anon_key_anahtarin_buraya_gelecek

# Port Bilgileri (Örnek)
VITE_CLIENT_PORT=3200
VITE_ADMIN_PORT=3201

# Shopier Ödeme Entegrasyonu (Örnek)
# NOT: Bu bilgileri asla client-side kullanmayin. Supabase Edge Function veya benzeri bir backend uzerinden Shopier API'sine erisin.
VITE_SHOPIER_API_KEY=shopier_api_key_buraya_gelecek
VITE_SHOPIER_API_SECRET=shopier_api_secret_buraya_gelecek
VITE_SHOPIER_API_URL=https://api.shopier.com/api/v1
VITE_SHOPIER_CALLBACK_URL=https://site-adresin.com/payment/callback
VITE_SHOPIER_RETURN_URL=https://site-adresin.com/payment/result